local function GetClosestPlayerToMouse()
    local closestDist = math.huge
    local closestTarget = nil
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if not myRoot then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local targetPos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(targetPos.X, targetPos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closestTarget = p
                end
            end
        end
    end
    return closestTarget
end

local function GetTargets()
    local targets = {}
    if Config.TargetPlayer == "ALL" then
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then table.insert(targets, p) end end
    elseif Config.TargetPlayer == "CLOSEST" then
        local closest = GetClosestPlayerToMouse()
        if closest then table.insert(targets, closest) end
    else
        local p = Players:FindFirstChild(Config.TargetPlayer)
        if p and p ~= LocalPlayer then table.insert(targets, p) end
    end
    return targets
end

local function TeleportTargets()
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local targetCFrame = myRoot.CFrame * CFrame.new(0, 0, Config.BringDistance)

    for _, player in ipairs(GetTargets()) do
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
            local hum, root = char.Humanoid, char.HumanoidRootPart
            hum.Sit, hum.PlatformStand = false, false
            if char:FindFirstChild("Ragdoll") then char.Ragdoll:Destroy() end
            root.Velocity, root.RotVelocity = Vector3.new(0,0,0), Vector3.new(0,0,0)
            for i = 1, 3 do root.CFrame = targetCFrame end
        end
    end
end

local function SimulateKeyPress(keyCode)
    task.spawn(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.02) 
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

local function ExecuteBringCombo()
    if Config.ActionDelay < 0 then
        SimulateKeyPress(Config.SelectedKey)
        task.wait(math.abs(Config.ActionDelay))
        TeleportTargets()
    elseif Config.ActionDelay > 0 then
        TeleportTargets()
        task.wait(Config.ActionDelay)
        SimulateKeyPress(Config.SelectedKey)
    else
        task.spawn(TeleportTargets)
        SimulateKeyPress(Config.SelectedKey)
    end
end

local SpamConnection
local function UpdateSpamBring()
    if Config.SpamBringEnabled and not SpamConnection then
        SpamConnection = RunService.RenderStepped:Connect(TeleportTargets)
    elseif not Config.SpamBringEnabled and SpamConnection then
        SpamConnection:Disconnect(); SpamConnection = nil
    end
    SaveSettings()
end

local SeqComboRunning = false
local function UpdateSeqCombo()
    if Config.SeqComboEnabled then
        if not SeqComboRunning then
            SeqComboRunning = true
            task.spawn(function()
                while Config.SeqComboEnabled do
                    for i = 1, 4 do
                        if not Config.SeqComboEnabled then break end
                        SimulateKeyPress(KeyMap[i])
                        task.wait(Config.SeqComboDelay)
                    end
                end
                SeqComboRunning = false
            end)
        end
    else
        SeqComboRunning = false
    end
    SaveSettings()
end

