    lbl.Text = "Auto-Press Skill Key"; lbl.TextColor3 = UIColors.TextMain; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local btnContainer = Instance.new("Frame", row)
    btnContainer.Size = UDim2.new(0.6, -10, 1, 0); btnContainer.Position = UDim2.new(0.4, 0, 0, 0); btnContainer.BackgroundTransparency = 1
    
    local KeyBtns = {}
    local function MakeBtn(num, xOffset)
        local b = Instance.new("TextButton", btnContainer)
        b.Size = UDim2.new(0, 34, 0, 26); b.Position = UDim2.new(1, xOffset, 0.5, -13)
        b.BackgroundColor3 = (Config.SelectedKey == KeyMap[num]) and UIColors.AccentColor or UIColors.SidebarBg
        b.Text = tostring(num); b.TextColor3 = Color3.fromRGB(255,255,255); b.Font = Enum.Font.GothamBlack; b.TextSize = 12
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6); Instance.new("UIStroke", b).Color = UIColors.Border
        
        b.MouseButton1Click:Connect(function()
            Config.SelectedKey = KeyMap[num]
            for _, x in pairs(KeyBtns) do TweenService:Create(x, TweenInfo.new(0.2), {BackgroundColor3 = UIColors.SidebarBg}):Play() end
            TweenService:Create(b, TweenInfo.new(0.2), {BackgroundColor3 = UIColors.AccentColor}):Play()
            SaveSettings()
        end)
        table.insert(KeyBtns, b)
    end
    MakeBtn(4, -34); MakeBtn(3, -74); MakeBtn(2, -114); MakeBtn(1, -154)
end

