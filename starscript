    local circle = Instance.new("Frame", toggleBtn)
    circle.Size = UDim2.new(0, 14, 0, 14); circle.Position = defaultState and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
