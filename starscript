-- 3. CHAOTIC FLING & ABSOLUTE ANCHOR
-- ==========================================
local isFlinging = false

local function ExecuteMassFling()
    if isFlinging then return end
    
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local myHum = myChar and myChar:FindFirstChild("Humanoid")
    if not myRoot or not myHum then return end

    isFlinging = true
    local originalCFrame = myRoot.CFrame
    
    local targets = {}
    for name, isSelected in pairs(Config.FlingTargets) do
        if isSelected then
            local p = Players:FindFirstChild(name)
            if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                table.insert(targets, p)
            end
        end
    end

    if #targets == 0 then 
        isFlinging = false 
        return 
    end

    local oldPhysicalProperties = {}
    for _, part in pairs(myChar:GetDescendants()) do
        if part:IsA("BasePart") then 
            oldPhysicalProperties[part] = part.CustomPhysicalProperties
            part.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
        end
    end

    local spinVelocity = Instance.new("BodyAngularVelocity")
    spinVelocity.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    spinVelocity.AngularVelocity = Vector3.new(100000, 100000, 100000)
    spinVelocity.Parent = myRoot

    for _, targetPlayer in ipairs(targets) do
        local tChar = targetPlayer.Character
        if tChar and tChar:FindFirstChild("HumanoidRootPart") then
            local tRoot = tChar.HumanoidRootPart
            local startTime = tick()
            
            while tChar and tRoot and (tick() - startTime) < 1.5 do
                RunService.Heartbeat:Wait()
                
                local randX = (math.random() - 0.5) * 5
                local randY = (math.random() - 0.5) * 5
                local randZ = (math.random() - 0.5) * 5
                
                myRoot.CFrame = tRoot.CFrame * CFrame.new(randX, randY, randZ)
                
                myRoot.Velocity = Vector3.new(
                    math.random(-50000, 50000), 
                    math.random(-50000, 50000), 
                    math.random(-50000, 50000)
                )
            end
        end
    end

    if spinVelocity then spinVelocity:Destroy() end
    for part, oldProp in pairs(oldPhysicalProperties) do
        if part and part.Parent then
            part.CustomPhysicalProperties = oldProp
        end
    end
    
    myRoot.Velocity = Vector3.new(0,0,0)
    myRoot.RotVelocity = Vector3.new(0,0,0)
    myRoot.CFrame = originalCFrame
    task.wait(0.5) 
    isFlinging = false
end

local AnchorCFrame = nil
local AbsoluteAnchorConn = nil

local function UpdateAbsoluteAnchor()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if Config.AbsoluteAnchorEnabled then
        if myRoot and not AnchorCFrame then
            AnchorCFrame = myRoot.CFrame + Vector3.new(0, 30, 0)
        end
        
        if not AbsoluteAnchorConn then
            AbsoluteAnchorConn = RunService.Stepped:Connect(function()
                if AnchorCFrame and LocalPlayer.Character then
                    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        root.Velocity = Vector3.new(0, 0, 0)
                        root.RotVelocity = Vector3.new(0, 0, 0)
                        root.CFrame = AnchorCFrame
                        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                            if part:IsA("BasePart") then part.CanCollide = false end
                        end
                    end
                end
            end)
        end
    else
        if AbsoluteAnchorConn then
            AbsoluteAnchorConn:Disconnect()
            AbsoluteAnchorConn = nil
        end
        AnchorCFrame = nil
        if myChar then
            for _, part in pairs(myChar:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then part.CanCollide = true end
            end
        end
    end
end

