local function SaveSettings()
    if writefile then
        local saveTable = {}
        for k, v in pairs(Config) do
            if typeof(v) == "EnumItem" then saveTable[k] = v.Name else saveTable[k] = v end
        end
        pcall(function() writefile(ConfigFileName, HttpService:JSONEncode(saveTable)) end)
    end
end

local function LoadSettings()
    if readfile and isfile and isfile(ConfigFileName) then
        pcall(function()
            local data = HttpService:JSONDecode(readfile(ConfigFileName))
            if data then
                for k, v in pairs(data) do
                    if Config[k] ~= nil then
                        if typeof(Config[k]) == "EnumItem" then Config[k] = Enum.KeyCode[v] or Config[k]
                        else Config[k] = v end
                    end
                end
            end
        end)
    end
end

