    layout.Padding = UDim.new(0, 4)

    local selectAllBtn = Instance.new("TextButton", frame)
    selectAllBtn.Size = UDim2.new(0.5, -12, 0, 20); selectAllBtn.Position = UDim2.new(0, 8, 1, -25)
    selectAllBtn.BackgroundColor3 = UIColors.Background; selectAllBtn.Text = "Select All"
    selectAllBtn.TextColor3 = UIColors.Text; selectAllBtn.Font = Enum.Font.Gotham; selectAllBtn.TextSize = 10
    Instance.new("UICorner", selectAllBtn).CornerRadius = UDim.new(0, 4)
    
    local deselectAllBtn = Instance.new("TextButton", frame)
    deselectAllBtn.Size = UDim2.new(0.5, -12, 0, 20); deselectAllBtn.Position = UDim2.new(0.5, 4, 1, -25)
    deselectAllBtn.BackgroundColor3 = UIColors.Background; deselectAllBtn.Text = "Deselect All"
    deselectAllBtn.TextColor3 = UIColors.Text; deselectAllBtn.Font = Enum.Font.Gotham; deselectAllBtn.TextSize = 10
    Instance.new("UICorner", deselectAllBtn).CornerRadius = UDim.new(0, 4)

    local function RefreshList()
        for _, child in pairs(scroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
        for i = #ThemedPlayerListBtns, 1, -1 do
            if ThemedPlayerListBtns[i].Table == targetTable then table.remove(ThemedPlayerListBtns, i) end
        end

        local yOffset = 0
        local pList = Players:GetPlayers()
        table.sort(pList, function(a, b) return a.Name:lower() < b.Name:lower() end)

        for _, p in ipairs(pList) do
            if p ~= LocalPlayer then
                local btn = Instance.new("TextButton", scroll)
                btn.Size = UDim2.new(1, -8, 0, 22)
                btn.BackgroundColor3 = targetTable[p.Name] and CurrentThemeColor or UIColors.Background
                btn.Text = "  " .. p.Name
                btn.TextColor3 = UIColors.Text
                btn.Font = Enum.Font.Gotham; btn.TextSize = 10
                btn.TextXAlignment = Enum.TextXAlignment.Left
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

                table.insert(ThemedPlayerListBtns, {Btn = btn, Table = targetTable, Name = p.Name})

                btn.MouseButton1Click:Connect(function()
                    targetTable[p.Name] = not targetTable[p.Name]
                    PlaySound(targetTable[p.Name])
                end)
                yOffset = yOffset + 26
            end
        end
        scroll.CanvasSize = UDim2.new(0, 0, 0, yOffset)
    end

    selectAllBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then targetTable[p.Name] = true end end
        PlaySound(true)
    end)
    
    deselectAllBtn.MouseButton1Click:Connect(function()
        for k in pairs(targetTable) do targetTable[k] = false end
        PlaySound(false)
    end)

    Players.PlayerAdded:Connect(RefreshList); Players.PlayerRemoving:Connect(RefreshList)
    RefreshList()
end

