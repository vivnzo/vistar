local function GetBringTargets()
    local targets = {}
    if Config.TargetPlayer == "ALL" then
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then table.insert(targets, p) end end
    elseif Config.TargetPlayer == "SELECTED LIST" then
        for name, isSelected in pairs(Config.BringTargets) do
            if isSelected then
                local p = Players:FindFirstChild(name)
                if p and p ~= LocalPlayer then table.insert(targets, p) end
            end
        end
    end
    return targets
end

local function TeleportTargets()
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local targetCFrame = myRoot.CFrame * CFrame.new(0, 0, Config.BringDistance)

    for _, player in ipairs(GetBringTargets()) do
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
            local hum, root = char.Humanoid, char.HumanoidRootPart
            hum.Sit, hum.PlatformStand = false, false
            if char:FindFirstChild("Ragdoll") then char.Ragdoll:Destroy() end
            root.Velocity, root.RotVelocity = Vector3.new(0,0,0), Vector3.new(0,0,0)
            for i = 1, 3 do root.CFrame = targetCFrame end
        end
    end
end

local SpamConnection
local function UpdateSpamBring()
    if Config.SpamBringEnabled and not SpamConnection then
        SpamConnection = RunService.RenderStepped:Connect(TeleportTargets)
    elseif not Config.SpamBringEnabled and SpamConnection then
        SpamConnection:Disconnect()
        SpamConnection = nil
    end
    SaveSettings()
end

local AnchorCFrame = nil
local AbsoluteAnchorConn = nil
local function UpdateAbsoluteAnchor()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if Config.AbsoluteAnchorEnabled then
        if myRoot and not AnchorCFrame then AnchorCFrame = myRoot.CFrame + Vector3.new(0, 30, 0) end
        if not AbsoluteAnchorConn then
            AbsoluteAnchorConn = RunService.Stepped:Connect(function(runtime, dt)
                if AnchorCFrame and LocalPlayer.Character then
                    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                    if root and hum then
                        local moveDirection = Vector3.new(0, 0, 0)
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection = moveDirection + Camera.CFrame.LookVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection = moveDirection - Camera.CFrame.LookVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection = moveDirection - Camera.CFrame.RightVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection = moveDirection + Camera.CFrame.RightVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDirection = moveDirection + Vector3.new(0, 1, 0) end
                        
                        if moveDirection.Magnitude > 0 then AnchorCFrame = AnchorCFrame + (moveDirection.Unit * 60 * (dt or 0.016)) end
                        
                        root.Velocity = Vector3.new(0, 0, 0)
                        root.RotVelocity = Vector3.new(0, 0, 0)
                        
                        local lookVector = Camera.CFrame.LookVector
                        local flatLook = Vector3.new(lookVector.X, 0, lookVector.Z).Unit
                        if flatLook.Magnitude == 0 or tostring(flatLook.X) == "-nan(ind)" then flatLook = Vector3.new(0, 0, -1) end
                        
                        root.CFrame = CFrame.new(AnchorCFrame.Position) * CFrame.lookAt(Vector3.new(0,0,0), flatLook).Rotation
                        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                            if part:IsA("BasePart") then part.CanCollide = false end
                        end
                    end
                end
            end)
        end
    else
        if AbsoluteAnchorConn then AbsoluteAnchorConn:Disconnect() AbsoluteAnchorConn = nil end
        AnchorCFrame = nil
        if myChar then
            for _, part in pairs(myChar:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then part.CanCollide = true end
            end
        end
    end
end

