    lastTick = currentTick
    if Config.ShowWatermark then 
        local pingVal = 0
        pcall(function() pingVal = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
        StatsLabel.Text = "FPS: " .. fps .. " | PING: " .. pingVal .. "ms"
    end

    StrokeGradient.Rotation = (StrokeGradient.Rotation + Config.UIStrokeSpeed) % 360

    if IsRainbow then
        local hue = tick() % 5 / 5
        local rainbowColor = Color3.fromHSV(hue, 1, 1)
        CurrentThemeColor = rainbowColor
        
        StrokeGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, rainbowColor),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(rainbowColor.R*0.3, rainbowColor.G*0.3, rainbowColor.B*0.3)),
            ColorSequenceKeypoint.new(1, rainbowColor)
        })

        for _, txt in pairs(ThemedTexts) do txt.TextColor3 = rainbowColor end
        for _, strk in pairs(ThemedStrokes) do strk.Color = rainbowColor end
        for _, scr in pairs(ScrollFrames) do scr.ScrollBarImageColor3 = rainbowColor end
        for _, bg in pairs(ThemedBackgrounds) do
            if bg.IsToggle then
                if bg.GetState() then bg.Element.BackgroundColor3 = rainbowColor end
            else
                bg.Element.BackgroundColor3 = rainbowColor
            end
        end
        for _, tb in pairs(TabButtonsList) do
            if tb.IsActive then tb.Btn.BackgroundColor3 = rainbowColor end
        end
    end

    for _, trail in ipairs(ActiveTrails) do
        if trail and trail.Parent then
            trail.Color = ColorSequence.new(CurrentThemeColor)
        end
    end

    for _, item in pairs(ThemedPlayerListBtns) do
        if item.Btn and item.Btn.Parent then
            if item.Table[item.Name] then
                item.Btn.BackgroundColor3 = CurrentThemeColor
            else
                item.Btn.BackgroundColor3 = UIColors.Background
            end
        end
    end
    
    -- إضافة تحديث الألوان لقائمة الإكسسوارات ليظل مضيئاً عند التحديد
    for _, item in pairs(ThemedAccessoryListBtns) do
