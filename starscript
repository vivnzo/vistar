                    optBtn.Text = (isSelected and " [X] " or " [ ] ") .. pName
                    optBtn.TextColor3 = isSelected and UIColors.AccentColor or UIColors.TextMuted
                    SaveSettings()
                end)
            end
            listFrame.CanvasSize = UDim2.new(0, 0, 0, #playersList * 26)
        end
    end)
end

-- Acrylic Slider
local function CreateSlider(parent, title, min, max, defaultVal, isFloat, callback)
    local row = CreateAcrylicRow(parent, 50)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -20, 0, 24); lbl.Position = UDim2.new(0, 10, 0, 0); lbl.BackgroundTransparency = 1
    lbl.TextColor3 = UIColors.TextMain; lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local bgBar = Instance.new("Frame", row)
    bgBar.Size = UDim2.new(1, -20, 0, 8); bgBar.Position = UDim2.new(0, 10, 0, 30); bgBar.BackgroundColor3 = Color3.fromRGB(30, 20, 45)
    Instance.new("UICorner", bgBar).CornerRadius = UDim.new(1, 0)
    local fillBar = Instance.new("Frame", bgBar)
    fillBar.BackgroundColor3 = UIColors.AccentColor; fillBar.Size = UDim2.new(0, 0, 1, 0)
    Instance.new("UICorner", fillBar).CornerRadius = UDim.new(1, 0)
    
    local function SetValue(val)
        local pct = math.clamp((val - min) / (max - min), 0, 1)
        fillBar.Size = UDim2.new(pct, 0, 1, 0)
        local dVal = isFloat and (math.floor(val * 10 + 0.5) / 10) or math.floor(val)
        lbl.Text = title .. ": " .. dVal; callback(val)
    end
    SetValue(defaultVal)
    
    local draggingSlider = false
    bgBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingSlider = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingSlider = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if draggingSlider and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local pct = math.clamp((i.Position.X - bgBar.AbsolutePosition.X) / bgBar.AbsoluteSize.X, 0, 1)
            local raw = min + (max - min) * pct
            SetValue(isFloat and (math.floor(raw * 10 + 0.5) / 10) or math.floor(raw + 0.5))
        end
    end)
end

