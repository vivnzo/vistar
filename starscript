    toggleBtn.MouseButton1Click:Connect(function()
        state = not state; PlaySound(state)
        TweenService:Create(toggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = state and CurrentThemeColor or Color3.fromRGB(50, 50, 50)}):Play()
        TweenService:Create(circle, TweenInfo.new(0.2), {Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
