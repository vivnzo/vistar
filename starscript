local function PerfectEquip(itemName)
    local character = LocalPlayer.Character
    if not character then return false, "NO CHAR" end

    local targetItem = nil
    for _, obj in pairs(game:GetDescendants()) do
        if obj.Name == itemName and (obj:IsA("Accessory") or obj:IsA("Model")) then
            if not obj:IsA("Folder") and not obj:IsA("StringValue") then
                targetItem = obj
                break
            end
        end
    end

    if not targetItem then return false, "NOT FOUND" end

    if character:FindFirstChild(itemName) then 
        character[itemName]:Destroy() 
    end

    local clone = targetItem:Clone()
    clone.Name = itemName
    clone.Parent = character

    local handle = clone:FindFirstChild("Handle") or clone:FindFirstChildWhichIsA("BasePart")
    if not handle then
        handle = clone.PrimaryPart or clone:FindFirstChildWhichIsA("MeshPart")
    end

    if handle then
        local itemAttachment = clone:FindFirstChildWhichIsA("Attachment", true)
        local characterAttachment = nil
        if itemAttachment then
            characterAttachment = character:FindFirstChild(itemAttachment.Name, true)
        end

        local weld = Instance.new("WeldConstraint")
        weld.Name = "VI_HOEP_Weld"

        if characterAttachment and itemAttachment then
            handle.CFrame = characterAttachment.WorldCFrame * itemAttachment.CFrame:Inverse()
            weld.Part0 = characterAttachment.Parent
            weld.Part1 = handle
            weld.Parent = handle
        else
            local upperTorso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
            local head = character:FindFirstChild("Head")
            
            if string.match(string.lower(itemName), "wheel") or string.match(string.lower(itemName), "clover") or string.match(string.lower(itemName), "back") then
                handle.CFrame = upperTorso.CFrame * CFrame.new(0, 0, 1.2) * CFrame.Angles(0, math.rad(180), 0)
                weld.Part0 = upperTorso
            elseif string.match(string.lower(itemName), "mask") or string.match(string.lower(itemName), "face") or string.match(string.lower(itemName), "head") then
                handle.CFrame = head.CFrame * CFrame.new(0, 0, -0.6)
                weld.Part0 = head
            else
                handle.CFrame = upperTorso.CFrame * CFrame.new(0, 0, 1)
                weld.Part0 = upperTorso
            end
            weld.Part1 = handle
            weld.Parent = handle
        end
        
        for _, part in pairs(clone:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                part.CanCollide = false
                if part ~= handle then
                    local w = Instance.new("WeldConstraint")
                    w.Part0 = handle
                    w.Part1 = part
                    w.Parent = part
                end
            end
        end
    end

    for _, scr in pairs(clone:GetDescendants()) do
        if scr:IsA("LocalScript") or scr:IsA("ModuleScript") then
            scr.Disabled = true
            scr.Disabled = false
            scr.Parent = character
        end
    end

    return true, "READY"
end

local function RemoveAllAccessories()
    local char = LocalPlayer.Character
    if not char then return end
    
    local toRemove = {}
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Accessory") or 
           (child:IsA("Model") and child:FindFirstChild("Handle")) or
           (child:IsA("BasePart") and child:FindFirstChild("VI_HOEP_Weld")) then
            table.insert(toRemove, child)
        end
    end
    
    for _, obj in ipairs(toRemove) do
        obj:Destroy()
    end
    SendNotification("Accessories", "Removed " .. #toRemove .. " item(s).", 2)
end

