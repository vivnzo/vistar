local function SimulateKeyPress(keyCode)
    task.spawn(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

local function GetTargets()
    local targets = {}
    if Config.TargetPlayer == "ALL" then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then table.insert(targets, p) end
        end
    else
        local p = Players:FindFirstChild(Config.TargetPlayer)
        if p and p ~= LocalPlayer then table.insert(targets, p) end
    end
    return targets
end

local function TeleportTargets()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local targetCFrame = myRoot.CFrame * CFrame.new(0, 0, Config.BringDistance)
    local targets = GetTargets()

    for _, player in ipairs(targets) do
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
            char.Humanoid.Sit = false
            char.HumanoidRootPart.CFrame = targetCFrame
        end
    end
end

local function ExecuteBringCombo()
    if Config.ActionDelay < 0 then
        SimulateKeyPress(Config.SelectedKey)
        task.wait(math.abs(Config.ActionDelay))
        TeleportTargets()
    elseif Config.ActionDelay > 0 then
        TeleportTargets()
        task.wait(Config.ActionDelay)
        SimulateKeyPress(Config.SelectedKey)
    else
        SimulateKeyPress(Config.SelectedKey)
        TeleportTargets()
    end
end

-- ==========================================
-- أنظمة التكرار (Spam & Sequences)
-- ==========================================
local SpamBringConnection = nil
local function UpdateSpamBring()
    if Config.SpamBringEnabled then
        if not SpamBringConnection then
            SpamBringConnection = RunService.Heartbeat:Connect(function() TeleportTargets() end)
        end
    else
        if SpamBringConnection then
            SpamBringConnection:Disconnect()
            SpamBringConnection = nil
        end
    end
    SaveSettings()
end

local SeqComboRunning = false
local function UpdateSeqCombo()
    if Config.SeqComboEnabled then
        if not SeqComboRunning then
            SeqComboRunning = true
            task.spawn(function()
                while Config.SeqComboEnabled do
                    for i = 1, 4 do
                        if not Config.SeqComboEnabled then break end
                        SimulateKeyPress(KeyMap[i])
                        task.wait(Config.SeqComboDelay)
                    end
                end
                SeqComboRunning = false
            end)
        end
    else
        SeqComboRunning = false
    end
    SaveSettings()
end

