local function GetLinkPositions(char, link)
    local p1 = char:FindFirstChild(link[1])
    local p2 = char:FindFirstChild(link[2])
    if p1 and p2 then
        local pos1, vis1 = Camera:WorldToViewportPoint(p1.Position)
        local pos2, vis2 = Camera:WorldToViewportPoint(p2.Position)
        if vis1 or vis2 then
            return Vector2.new(pos1.X, pos1.Y), Vector2.new(pos2.X, pos2.Y)
        end
    end
    return nil, nil
end

local function CreateESP(player)
    local espNode = Instance.new("Folder", ESPFolder)
    
    local espFrame = Instance.new("Frame", espNode)
    espFrame.BackgroundTransparency = 1; espFrame.Visible = false
    
    local bgBar = Instance.new("Frame", espFrame)
    bgBar.Size = UDim2.new(0, 4, 1, 0); bgBar.Position = UDim2.new(0, -8, 0, 0)
    bgBar.BackgroundColor3 = Color3.fromRGB(15, 15, 15); bgBar.BorderSizePixel = 1; bgBar.BorderColor3 = Color3.fromRGB(0,0,0)
    
    local healthBar = Instance.new("Frame", bgBar)
    healthBar.Size = UDim2.new(1, 0, 1, 0); healthBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    healthBar.BorderSizePixel = 0; healthBar.AnchorPoint = Vector2.new(0, 1); healthBar.Position = UDim2.new(0, 0, 1, 0)
    
    local nameTag = Instance.new("TextLabel", espFrame)
    nameTag.Size = UDim2.new(0, 100, 0, 15); nameTag.Position = UDim2.new(0.5, -50, 0, -20)
    nameTag.BackgroundTransparency = 1; nameTag.Text = player.Name; nameTag.TextColor3 = Color3.fromRGB(255,255,255)
    nameTag.Font = Enum.Font.GothamBold; nameTag.TextSize = 11; nameTag.TextStrokeTransparency = 0.2

    local skeletonFrame = Instance.new("Frame", espNode)
    skeletonFrame.BackgroundTransparency = 1; skeletonFrame.Size = UDim2.new(1,0,1,0); skeletonFrame.Visible = true
    
    local lines = {}
    for i = 1, 15 do
        local line = Instance.new("Frame", skeletonFrame)
        line.AnchorPoint = Vector2.new(0.5, 0.5); line.BorderSizePixel = 0; line.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        line.Visible = false
        table.insert(lines, line)
