RunService.RenderStepped:Connect(function()
    if not Config.ShowESP then for _, data in pairs(ESPCache) do data.Frame.Visible = false end return end
    for player, data in pairs(ESPCache) do
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
            local hum, hrp = char.Humanoid, char.HumanoidRootPart
            local vector, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local headVector = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
            local legVector = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
             
            if onScreen then
                local height = math.abs(headVector.Y - legVector.Y); local width = height / 2
                data.Frame.Size = UDim2.new(0, width, 0, height)
                data.Frame.Position = UDim2.new(0, vector.X - width/2, 0, headVector.Y)
                data.Frame.Visible = true
                
                local healthPct = hum.Health / hum.MaxHealth
                data.HealthBar.Size = UDim2.new(1, 0, healthPct, 0)
                data.HealthBar.BackgroundColor3 = (healthPct >= 0.7) and Color3.fromRGB(0, 255, 100) or ((healthPct >= 0.3) and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(255, 50, 50))
            else data.Frame.Visible = false end
        else data.Frame.Visible = false end
    end
end)

