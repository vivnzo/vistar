    listFrame.BackgroundTransparency = 1; listFrame.ScrollBarThickness = 2; listFrame.ScrollBarImageColor3 = UIColors.AccentColor
    local listLayout = Instance.new("UIListLayout", listFrame)
    
    local expanded = false
    topBtn.MouseButton1Click:Connect(function()
        expanded = not expanded
        TweenService:Create(container, TweenInfo.new(0.3), {Size = expanded and UDim2.new(1, -8, 0, 180) or UDim2.new(1, -8, 0, 36)}):Play()
        if expanded then
            for _, c in pairs(listFrame:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
            
            local playersList = {}
            for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then table.insert(playersList, p.Name) end end
            
