local function SaveSettings()
    if writefile then
        local saveTable = {}
        for k, v in pairs(Config) do
            if typeof(v) == "EnumItem" then
                saveTable[k] = v.Name
            else
                saveTable[k] = v
            end
        end
        pcall(function() writefile(ConfigFileName, HttpService:JSONEncode(saveTable)) end)
    end
end

local function LoadSettings()
    if readfile and isfile and isfile(ConfigFileName) then
        pcall(function()
            local data = HttpService:JSONDecode(readfile(ConfigFileName))
            if data then
                if data.TargetPlayer then Config.TargetPlayer = data.TargetPlayer end
                if data.ActionDelay then Config.ActionDelay = data.ActionDelay end
                if data.SpamBringEnabled ~= nil then Config.SpamBringEnabled = data.SpamBringEnabled end
                if data.ShowStats ~= nil then Config.ShowStats = data.ShowStats end
                if data.SeqComboEnabled ~= nil then Config.SeqComboEnabled = data.SeqComboEnabled end
                if data.SeqComboDelay then Config.SeqComboDelay = data.SeqComboDelay end
                if data.SelectedKey then Config.SelectedKey = Enum.KeyCode[data.SelectedKey] or Enum.KeyCode.One end
            end
        end)
    end
end
