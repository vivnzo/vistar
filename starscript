local function UpdateThemeColor(newColorName)
    if newColorName == "Rainbow" then IsRainbow = true
    else
        IsRainbow = false; CurrentThemeColor = PresetColors[newColorName] or PresetColors["Purple"]
        StrokeGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, CurrentThemeColor),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(CurrentThemeColor.R*0.3, CurrentThemeColor.G*0.3, CurrentThemeColor.B*0.3)),
