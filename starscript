local AnchorCFrame = nil
local AbsoluteAnchorConn = nil
local OriginalCollisions = {}

local function UpdateAbsoluteAnchor()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if Config.AbsoluteAnchorEnabled then
        if myRoot and not AnchorCFrame then 
            AnchorCFrame = myRoot.CFrame + Vector3.new(0, 30, 0) 
            OriginalCollisions = {}
            for _, part in pairs(myChar:GetDescendants()) do
                if part:IsA("BasePart") then
                    OriginalCollisions[part] = part.CanCollide
                end
            end
        end
        if not AbsoluteAnchorConn then
            AbsoluteAnchorConn = RunService.Stepped:Connect(function(runtime, dt)
                if AnchorCFrame and LocalPlayer.Character then
                    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                    
                    if root and hum then
                        local deltaTime = dt or 0.016
                        local flySpeed = 60
                        local moveDirection = Vector3.new(0, 0, 0)
                        
                        -- Mobile & PC Movement Logic (Reading Joystick + Camera Direction)
                        local moveVector = hum.MoveDirection
                        local camLook = Camera.CFrame.LookVector
                        local camRight = Camera.CFrame.RightVector
                        
                        -- Normalize to ignore Y for dot product calculations
                        local flatCamLook = Vector3.new(camLook.X, 0, camLook.Z).Unit
                        if flatCamLook.Magnitude == 0 or tostring(flatCamLook.X) == "-nan(ind)" then flatCamLook = Vector3.new(0, 0, -1) end
                        local flatCamRight = Vector3.new(camRight.X, 0, camRight.Z).Unit
                        
                        if moveVector.Magnitude > 0 then
                            local forwardInput = moveVector:Dot(flatCamLook)
                            local rightInput = moveVector:Dot(flatCamRight)
                            moveDirection = (camLook * forwardInput) + (camRight * rightInput)
                        end
                        
                        -- PC and Mobile Jump/Descend Support
                        if UserInputService:GetJumpState() or UserInputService:IsKeyDown(Enum.KeyCode.Space) then 
                            moveDirection = moveDirection + Vector3.new(0, 1, 0) 
                        end
                        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then 
                            moveDirection = moveDirection - Vector3.new(0, 1, 0) 
                        end
                        
                        if moveDirection.Magnitude > 0 then
                            AnchorCFrame = AnchorCFrame + (moveDirection.Unit * flySpeed * deltaTime)
                        end
                        
                        root.Velocity = Vector3.new(0, 0, 0)
                        root.RotVelocity = Vector3.new(0, 0, 0)
                        
                        local flatLook = Vector3.new(camLook.X, 0, camLook.Z).Unit
                        if flatLook.Magnitude == 0 or tostring(flatLook.X) == "-nan(ind)" then 
                            flatLook = Vector3.new(0, 0, -1) 
                        end
                        
                        root.CFrame = CFrame.new(AnchorCFrame.Position) * CFrame.lookAt(Vector3.new(0,0,0), flatLook).Rotation
                        
                        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                            if part:IsA("BasePart") then part.CanCollide = false end
                        end
                    end
                end
            end)
        end
    else
        if AbsoluteAnchorConn then AbsoluteAnchorConn:Disconnect() AbsoluteAnchorConn = nil end
        AnchorCFrame = nil
        if myChar then
            for part, state in pairs(OriginalCollisions) do
                if part and part.Parent then
                    part.CanCollide = state
                end
            end
            OriginalCollisions = {}
        end
    end
end

local ActiveTrails = {}
local function CreateTrail(parentAttachment)
    local a0 = Instance.new("Attachment", parentAttachment)
    a0.Position = Vector3.new(0, 0.5, 0)
    local a1 = Instance.new("Attachment", parentAttachment)
    a1.Position = Vector3.new(0, -0.5, 0)
    
    local trail = Instance.new("Trail", parentAttachment)
    trail.Attachment0 = a0
    trail.Attachment1 = a1
    trail.Lifetime = 0.4
    trail.MinLength = 0.05
    trail.WidthScale = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)})
    trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 1)})
    trail.Color = ColorSequence.new(CurrentThemeColor)
    
    table.insert(ActiveTrails, trail)
end

local function UpdateAuraState()
    for _, trail in ipairs(ActiveTrails) do
        if trail and trail.Parent then trail:Destroy() end
    end
    ActiveTrails = {}
    
    if Config.ShowAura then
        local char = LocalPlayer.Character
        if char then
            local right = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm")
            local left = char:FindFirstChild("LeftHand") or char:FindFirstChild("Left Arm")
            if right then CreateTrail(right) end
            if left then CreateTrail(left) end
        end
    end
end

