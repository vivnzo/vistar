RunService.RenderStepped:Connect(function()
    for player, data in pairs(ESPCache) do
        local char = player.Character
        local alive = char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0
        
        if not alive then
            data.Frame.Visible = false
            for _, l in ipairs(data.SkeletonLines) do l.Visible = false end
            continue
        end

        local hum, hrp = char.Humanoid, char.HumanoidRootPart

        if Config.ShowSkeleton then
            local links = hum.RigType == Enum.HumanoidRigType.R15 and SkeletonLinksR15 or SkeletonLinksR6
            for i = 1, 15 do
                local line = data.SkeletonLines[i]
                local link = links[i]
                if link then
                    local pos1, pos2 = GetLinkPositions(char, link)
                    if pos1 and pos2 then
                        local center = (pos1 + pos2) / 2
                        local dist = (pos1 - pos2).Magnitude
                        local angle = math.atan2(pos2.Y - pos1.Y, pos2.X - pos1.X)
                        line.Position = UDim2.new(0, center.X, 0, center.Y)
                        line.Size = UDim2.new(0, dist, 0, 1.5)
                        line.Rotation = math.deg(angle)
                        line.BackgroundColor3 = CurrentThemeColor
                        line.Visible = true
                    else
                        line.Visible = false
                    end
                else
                    line.Visible = false
                end
            end
        else
            for _, l in ipairs(data.SkeletonLines) do l.Visible = false end
        end

        if Config.ShowESP then
            local vector, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local headVector = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
            local legVector = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
            
            if onScreen then
                local height = math.abs(headVector.Y - legVector.Y); local width = height / 2
                data.Frame.Size = UDim2.new(0, width, 0, height)
                data.Frame.Position = UDim2.new(0, vector.X - width/2, 0, headVector.Y)
                data.Frame.Visible = true
                
                local healthPct = hum.Health / hum.MaxHealth
                data.HealthBar.Size = UDim2.new(1, 0, healthPct, 0)
                data.HealthBar.BackgroundColor3 = (healthPct >= 0.7) and Color3.fromRGB(0, 255, 100) or ((healthPct >= 0.3) and Color3.fromRGB(255, 170, 0) or Color3.fromRGB(255, 50, 50))
            else data.Frame.Visible = false end
        else data.Frame.Visible = false end
    end
end)

