local lastTick = tick()
RunService.RenderStepped:Connect(function()
    local currentTick = tick(); local fps = math.floor(1 / (currentTick - lastTick)); lastTick = currentTick
    if Config.ShowWatermark then Watermark.Text = "VI HOEP | FPS: " .. fps end

    StrokeGradient.Rotation = (StrokeGradient.Rotation + Config.UIStrokeSpeed) % 360

    if IsRainbow then
        local hue = tick() % 5 / 5
        local rainbowColor = Color3.fromHSV(hue, 1, 1)
        CurrentThemeColor = rainbowColor
        
        StrokeGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, rainbowColor),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(rainbowColor.R*0.3, rainbowColor.G*0.3, rainbowColor.B*0.3)),
            ColorSequenceKeypoint.new(1, rainbowColor)
        })

        for _, txt in pairs(ThemedTexts) do txt.TextColor3 = rainbowColor end
        for _, strk in pairs(ThemedStrokes) do strk.Color = rainbowColor end
        for _, scr in pairs(ScrollFrames) do scr.ScrollBarImageColor3 = rainbowColor end
        for _, bg in pairs(ThemedBackgrounds) do
            if bg.IsToggle then if bg.GetState() then bg.Element.BackgroundColor3 = rainbowColor end
            else bg.Element.BackgroundColor3 = rainbowColor end
        end
    end

    for _, item in pairs(ThemedPlayerListBtns) do
        if item.Btn and item.Btn.Parent then
            if item.Table[item.Name] then item.Btn.BackgroundColor3 = CurrentThemeColor
            else item.Btn.BackgroundColor3 = UIColors.Background end
        end
    end

    CombatPage.CanvasSize = UDim2.new(0, 0, 0, CombatLayout.AbsoluteContentSize.Y + 15)
    FlingPage.CanvasSize = UDim2.new(0, 0, 0, FlingLayout.AbsoluteContentSize.Y + 15)
