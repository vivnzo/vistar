local function UnlockAllCosmetics()
    local RemotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
    local foundAuras = {}
    local foundEmotes = {}
    
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("Folder") and (string.match(string.lower(obj.Name), "aura") or string.match(string.lower(obj.Name), "auras")) then
            for _, child in pairs(obj:GetChildren()) do
                if not child:IsA("Script") and not child:IsA("LocalScript") then 
                    foundAuras[child.Name] = true 
                end
            end
        elseif obj:IsA("Animation") then
            foundEmotes[obj.Name] = true
        end
    end
    
    if RemotesFolder then
        local AuraListEvent = RemotesFolder:FindFirstChild("UpdateAuraList")
        if AuraListEvent and firesignal then
            for name, _ in pairs(foundAuras) do
                pcall(function() firesignal(AuraListEvent.OnClientEvent, name) end)
            end
        end
        
        local EmoteListEvent = RemotesFolder:FindFirstChild("UpdateEmoteList") or RemotesFolder:FindFirstChild("UpdateDanceList")
        if EmoteListEvent and firesignal then
            for name, _ in pairs(foundEmotes) do
                pcall(function() firesignal(EmoteListEvent.OnClientEvent, name) end)
            end
        end
    end
    
    SendNotification("Ultimate Unlocker", "Unlocked all available Auras and Emotes!", 4)
end

