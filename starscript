local AnchorCFrame = nil
local AbsoluteAnchorConn = nil
local OriginalCollisions = {}
local OriginalPlatformStand = false
local OriginalAutoRotate = false

local function UpdateAbsoluteAnchor()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local hum = myChar and myChar:FindFirstChildOfClass("Humanoid")
    
    if Config.AbsoluteAnchorEnabled then
        if myRoot and hum then
            OriginalPlatformStand = hum.PlatformStand
            OriginalAutoRotate = hum.AutoRotate
            hum.PlatformStand = true
            hum.AutoRotate = false
            OriginalCollisions = {}
            for _, part in pairs(myChar:GetDescendants()) do
                if part:IsA("BasePart") then
                    OriginalCollisions[part] = part.CanCollide
                    part.CanCollide = false
                end
            end
            if not AnchorCFrame then
                AnchorCFrame = myRoot.CFrame + Vector3.new(0, 30, 0)
            end
        end
        
        if not AbsoluteAnchorConn then
            AbsoluteAnchorConn = RunService.Stepped:Connect(function(runtime, dt)
                if AnchorCFrame and LocalPlayer.Character then
                    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local hum2 = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                    
                    if root and hum2 then
                        local deltaTime = dt or 0.016
                        local flySpeed = 60
                        local moveDirection = Vector3.new(0, 0, 0)
                        
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection = moveDirection + Camera.CFrame.LookVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection = moveDirection - Camera.CFrame.LookVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection = moveDirection - Camera.CFrame.RightVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection = moveDirection + Camera.CFrame.RightVector end
                        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDirection = moveDirection + Vector3.new(0, 1, 0) end
                        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDirection = moveDirection - Vector3.new(0, 1, 0) end
                        
                        if moveDirection.Magnitude > 0 then
                            AnchorCFrame = AnchorCFrame + (moveDirection.Unit * flySpeed * deltaTime)
                        end
                        
                        root.Velocity = Vector3.new(0, 0, 0)
                        root.RotVelocity = Vector3.new(0, 0, 0)
                        
                        local lookVector = Camera.CFrame.LookVector
                        local flatLook = Vector3.new(lookVector.X, 0, lookVector.Z).Unit
                        if flatLook.Magnitude == 0 or tostring(flatLook.X) == "-nan(ind)" then 
                            flatLook = Vector3.new(0, 0, -1) 
                        end
                        
                        root.CFrame = CFrame.new(AnchorCFrame.Position) * CFrame.lookAt(Vector3.new(0,0,0), flatLook).Rotation
                        hum2.PlatformStand = true
                    end
                end
            end)
        end
    else
        if AbsoluteAnchorConn then 
            AbsoluteAnchorConn:Disconnect() 
            AbsoluteAnchorConn = nil 
        end
        AnchorCFrame = nil
        if myChar and hum then
            hum.PlatformStand = OriginalPlatformStand
            hum.AutoRotate = OriginalAutoRotate
            for part, state in pairs(OriginalCollisions) do
                if part and part.Parent then
                    part.CanCollide = state
                end
            end
            OriginalCollisions = {}
        end
    end
end

